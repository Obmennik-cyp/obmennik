generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TelegramMessageStatus {
  DRAFT
  SCHEDULED
  SENT
  FAILED
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  phone    String
  password String

  role        String @default("employee")
  permissions String @default("[]")

  orders                Order[]            @relation("ClientOrders")
  assignedOrders        Order[]            @relation("EmployeeAssignedOrders")
  telegramTemplates     TelegramTemplate[]
  telegramMessages      TelegramMessage[]

  @@index([email])
  @@index([role])
}

model Order {
  id          Int    @id @default(autoincrement())
  orderNumber String @unique

  userId     Int
  employeeId Int?

  giveCurrency    String
  receiveCurrency String

  giveAmount    Float
  receiveAmount Float
  rate          Float
  feePercent    Float @default(0)

  status  OrderStatus @default(PENDING)
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User  @relation("ClientOrders", fields: [userId], references: [id])
  employee User? @relation("EmployeeAssignedOrders", fields: [employeeId], references: [id])

  @@index([userId])
  @@index([employeeId])
  @@index([status])
  @@index([createdAt])
}

model ExchangeRate {
  id              Int      @id @default(autoincrement())
  giveCurrency    String
  receiveCurrency String
  rate            Float
  feePercent      Float
  isActive        Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  @@unique([giveCurrency, receiveCurrency])
}

model TelegramTemplate {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  authorId    Int
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User     @relation(fields: [authorId], references: [id])
  messages    TelegramMessage[]

  @@index([authorId])
  @@index([isActive])
  @@index([createdAt])
}

model TelegramMessage {
  id               Int                   @id @default(autoincrement())
  title            String?
  content          String
  status           TelegramMessageStatus @default(DRAFT)

  authorId         Int
  templateId       Int?

  scheduledFor     DateTime?
  sentAt           DateTime?
  errorMessage     String?

  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  author           User                  @relation(fields: [authorId], references: [id])
  template         TelegramTemplate?     @relation(fields: [templateId], references: [id])

  @@index([authorId])
  @@index([templateId])
  @@index([status])
  @@index([scheduledFor])
  @@index([createdAt])
}