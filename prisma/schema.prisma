generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  phone    String
  password String

  role        String @default("employee")
  permissions String @default("[]")

  orders         Order[] @relation("ClientOrders")
  assignedOrders Order[] @relation("EmployeeAssignedOrders")
}

model Order {
  id          Int    @id @default(autoincrement())
  orderNumber String @unique

  userId     Int
  employeeId Int?

  giveCurrency    String
  receiveCurrency String

  giveAmount    Float
  receiveAmount Float
  rate          Float
  feePercent    Float @default(0)

  status  OrderStatus @default(PENDING)
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User  @relation("ClientOrders", fields: [userId], references: [id])
  employee User? @relation("EmployeeAssignedOrders", fields: [employeeId], references: [id])

  @@index([userId])
  @@index([employeeId])
  @@index([status])
  @@index([createdAt])
}

model ExchangeRate {
  id              Int      @id @default(autoincrement())
  giveCurrency    String
  receiveCurrency String
  rate            Float
  feePercent      Float
  isActive        Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  @@unique([giveCurrency, receiveCurrency])
}
